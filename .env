# Admin Signup Security
# Set to 'true' to allow signup without invitation token (only use during initial setup)
# Set to 'false' to require invitation tokens for all admin signups
VITE_ADMIN_SIGNUP_ENABLED="false"

# MTN SMS API Integration
# Get these from your MTN Developer Portal: https://developers.mtn.com
# NOTE: For security, actual MTN credentials should be set as Supabase Edge Function secrets:
#   supabase secrets set MTN_CLIENT_ID=xxx MTN_CLIENT_SECRET=xxx MTN_SUBSCRIPTION_KEY=xxx MTN_SHORT_CODE=xxx
# The VITE_MTN_* vars below are for reference/documentation only.
VITE_MTN_CLIENT_ID="your-mtn-client-id"
VITE_MTN_CLIENT_SECRET="your-mtn-client-secret"
# Optional: override the default API base URL (https://api.mtn.com)
# VITE_MTN_API_BASE_URL="https://api.mtn.com"

# Resend Email Integration
# Get your API key at https://resend.com/api-keys
# Set as a Supabase Edge Function secret (DO NOT add as VITE_ env var):
#   supabase secrets set RESEND_API_KEY=re_Ei3asjde_Be9jU3tutRR9vvgUq3QSniu2
# Verified sender domain: tennahubapps.com (must be verified in Resend)
# Default from address: TennaHub <noreply@tennahubapps.com>

# Evolution API (WhatsApp)
# Set up your Evolution API server: https://github.com/evolution-foundation/evolution-api
# These client-side env vars are for connecting instances (QR code scanning only).
# For sending messages, set as Supabase Edge Function secrets:
#   supabase secrets set EVOLUTION_API_URL=https://your-evolution-server.com EVOLUTION_API_KEY=your-api-key EVOLUTION_INSTANCE=your-instance
VITE_EVOLUTION_API_URL="http://localhost:8080"
VITE_EVOLUTION_API_KEY="your-evolution-api-key"
VITE_EVOLUTION_INSTANCE="parent-notifications"

